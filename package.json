{
  "name": "tabungan-bersama-kakak-mpip",
  "version": "2.5.1",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:compile": "node -e \"require('node:fs').rmSync('.test-dist',{recursive:true,force:true})\" && tsc -p tsconfig.test.json",
    "test": "npm run test:compile && node --test .test-dist/tests/core.test.js",
    "build": "npm run lint && npm run typecheck && npm test && next build",
    "start": "next start"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.4",
    "exceljs": "^4.4.0",
    "next": "15.5.19",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.0",
    "eslint-config-next": "15.5.19",
    "postcss": "^8.5.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.3"
  }
}
